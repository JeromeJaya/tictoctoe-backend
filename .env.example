# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com/
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<database-name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/tictactoe?retryWrites=true&w=majority

# Server Port
PORT=3000
